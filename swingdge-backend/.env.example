# ── Database (Supabase) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── SnapTrade ─────────────────────────────────────────────────────────────────
SNAPTRADE_CLIENT_ID=your_client_id
SNAPTRADE_CONSUMER_KEY=your_consumer_key
SNAPTRADE_USER_ID=your_registered_user_id
SNAPTRADE_USER_SECRET_ENCRYPTED=encrypted_value

# ── Market Data APIs ──────────────────────────────────────────────────────────
TWELVE_DATA_KEY=your_key
ALPHA_VANTAGE_KEY=your_key
FINNHUB_KEY=your_key
FMP_KEY=your_key
MARKETAUX_KEY=your_key

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=generate-a-long-random-string-here
FERNET_ENCRYPTION_KEY=generate-with-cryptography-fernet
TRIGGER_SECRET=generate-a-long-random-string-here
APP_PASSWORD=your-login-password

# ── App Settings ──────────────────────────────────────────────────────────────
RISK_PER_TRADE_PCT=1.0
DEFAULT_CURRENCY=CAD
FX_FEE_PCT=1.5
EARNINGS_BLACKOUT_DAYS=5
MAX_ACTIVE_TRADES=5
TRADE_EXPIRY_DAYS=10

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","https://swingdge.vercel.app"]

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
