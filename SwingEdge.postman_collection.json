{
  "info": {
    "name": "SwingEdge API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "trigger_secret",
      "value": "change-me-in-production",
      "type": "string"
    },
    {
      "key": "app_password",
      "value": "change-me",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "No auth required. Returns server status and version."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('token', json.access_token);",
                  "    console.log('Token saved to collection variable');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"{{app_password}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/login",
            "description": "Returns a JWT. The test script auto-saves it to the `token` collection variable."
          }
        }
      ]
    },
    {
      "name": "Portfolio",
      "item": [
        {
          "name": "Get Summary",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/portfolio/summary",
            "description": "Full portfolio with live prices, P&L per holding, sector weights, and health flags. Calls Twelve Data batch quotes."
          }
        },
        {
          "name": "Get All Holdings (raw)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/portfolio/holdings",
            "description": "Raw DB query of all holdings across all accounts. No live price fetch."
          }
        },
        {
          "name": "Get Accounts",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/portfolio/accounts",
            "description": "All accounts with balances and TFSA contribution room."
          }
        },
        {
          "name": "Add Holding",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account_id\": 1,\n  \"ticker\": \"AAPL\",\n  \"exchange\": \"NASDAQ\",\n  \"shares\": 10,\n  \"avg_cost\": 175.50,\n  \"currency\": \"USD\",\n  \"sector\": \"Technology\"\n}"
            },
            "url": "{{base_url}}/api/portfolio/holdings",
            "description": "Manually add a holding. Returns 409 if ticker already exists in that account. has_fx_cost is auto-set when currency is USD."
          }
        }
      ]
    },
    {
      "name": "Triggers (GitHub Actions)",
      "description": "These endpoints use TRIGGER_SECRET instead of JWT. Called by GitHub Actions cron workflows.",
      "item": [
        {
          "name": "Portfolio Sync (SnapTrade)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{trigger_secret}}" }
            ],
            "url": "{{base_url}}/api/trigger/portfolio-sync",
            "description": "Syncs holdings from Wealthsimple via SnapTrade. Fully implemented."
          }
        },
        {
          "name": "Cache Cleanup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{trigger_secret}}" }
            ],
            "url": "{{base_url}}/api/trigger/cache-cleanup",
            "description": "Deletes expired rows from the api_cache table. Fully implemented."
          }
        },
        {
          "name": "Morning Scan (Phase 2)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{trigger_secret}}" }
            ],
            "url": "{{base_url}}/api/trigger/morning-scan",
            "description": "Stub — Phase 2. Will run the full scanner pipeline."
          }
        },
        {
          "name": "Price Check (Phase 4)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{trigger_secret}}" }
            ],
            "url": "{{base_url}}/api/trigger/price-check",
            "description": "Stub — Phase 4. Will check active trades vs entry/stop/target prices."
          }
        },
        {
          "name": "Daily Summary (Phase 4)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{trigger_secret}}" }
            ],
            "url": "{{base_url}}/api/trigger/daily-summary",
            "description": "Stub — Phase 4. Will send Telegram daily summary."
          }
        },
        {
          "name": "Macro Update (Phase 3)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{trigger_secret}}" }
            ],
            "url": "{{base_url}}/api/trigger/macro-update",
            "description": "Stub — Phase 3. Will update BoC rate, commodities, USD/CAD."
          }
        },
        {
          "name": "Earnings Check (Phase 2)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{trigger_secret}}" }
            ],
            "url": "{{base_url}}/api/trigger/earnings-check",
            "description": "Stub — Phase 2. Will flag holdings with earnings this week."
          }
        },
        {
          "name": "Sector Update (Phase 3)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{trigger_secret}}" }
            ],
            "url": "{{base_url}}/api/trigger/sector-update",
            "description": "Stub — Phase 3. Will run sector rotation calculations."
          }
        }
      ]
    }
  ]
}
